# API backend khi chay production
# Khi chay local co the doi tam thanh http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=https://api.airplane.id.vn

# Khoa Gemini cho tro ly du lich hien tai.
# Chi can dien 1 trong 3 bien duoi day.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Model mac dinh cho Gemini o cac tinh nang chat thong thuong.
GEMINI_MODEL=gemini-2.5-flash

# Model mac dinh cho CopilotKit dat ve.
# Neu de trong, he thong tu dung google/gemini-2.5-flash.
COPILOTKIT_MODEL=gemini-2.5-flash

# Khoa OpenWeather cho tro ly du lich
OPENWEATHER_API_KEY=

# Chi can dien 1 trong 2 bien khoa NewsData duoi day
NEWSDATA_API_KEY=
NEWSDATAIO_API_KEY=
