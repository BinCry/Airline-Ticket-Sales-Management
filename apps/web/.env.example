# API backend khi chạy production
# Khi chạy local có thể đổi tạm thành http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=https://api.airplane.id.vn

# Chỉ cần khai báo 1 trong 2 biến khóa Gemini bên dưới.
# Nếu chưa muốn bật trợ lý AI, có thể để trống.
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Khóa OpenWeather cho trợ lý du lịch
OPENWEATHER_API_KEY=

# Chỉ cần khai báo 1 trong 2 biến khóa NewsData bên dưới
NEWSDATA_API_KEY=
NEWSDATAIO_API_KEY=
